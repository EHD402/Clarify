{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "dialog:default",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    },
    "sql:default",
    "sql:allow-execute"
  ]
}